{
  "inputs": [
    {
      "id": "taruvi-site-url",
      "type": "promptString",
      "description": "Taruvi site URL (e.g. https://tenant.taruvi.cloud)",
      "default": "${env:TARUVI_SITE_URL}"
    },
    {
      "id": "taruvi-api-key",
      "type": "promptString",
      "description": "Taruvi API Key",
      "password": true,
      "default": "${env:TARUVI_API_KEY}"
    },
    {
      "id": "taruvi-app-slug",
      "type": "promptString",
      "description": "Taruvi App Slug",
      "default": "${env:TARUVI_APP_SLUG}"
    }
  ],
  "servers": {
    "taruvi": {
      "url": "${input:taruvi-site-url}/mcp/",
      "headers": {
        "Authorization": "Api-Key ${input:taruvi-api-key}",
        "X-App-Slug": "${input:taruvi-app-slug}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "ctx7sk-b07da0a5-b392-4e88-8b99-095b7190feea"]
    }
  }
}
